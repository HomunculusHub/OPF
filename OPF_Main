-- ==========================================
-- LOOPS: AUTO TP MONSTERS
-- ==========================================
task.spawn(function()
    while true do
        if _G.AutoTP_CaveDemon or _G.AutoTP_Thief or _G.AutoTP_Vokun then
            pcall(function()
                local char = LocalPlayer.Character
                local myRoot = char and char:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    if not CheckValidTarget(ActiveMonsterTarget) then
                        ActiveMonsterTarget = nil
                        ActiveMonsterType = nil
                    end
                    if not ActiveMonsterTarget then
                        if _G.AutoTP_CaveDemon then
                            local f = FindTargetFromWorkspace("Cave Demon")
                            if f then ActiveMonsterTarget = f ActiveMonsterType = 1 end
                        end
                        if not ActiveMonsterTarget and _G.AutoTP_Thief then
                            local f = FindTargetFromWorkspace("Thief")
                            if f then ActiveMonsterTarget = f ActiveMonsterType = 2 end
                        end
                        if not ActiveMonsterTarget and _G.AutoTP_Vokun then
                            local f = FindTargetFromWorkspace("Vokun")
                            if f then ActiveMonsterTarget = f ActiveMonsterType = 3 end
                        end
                    end
                    if ActiveMonsterTarget then
                        local rootPart = ActiveMonsterTarget:FindFirstChild("HumanoidRootPart") or ActiveMonsterTarget.PrimaryPart
                        if rootPart then
                            local dir, dist = "Above", 5
                            if ActiveMonsterType == 1 then
                                dir = _G.DirOpt1 or "Above"
                                dist = _G.DistOpt1 or 5
                            elseif ActiveMonsterType == 2 then
                                dir = _G.DirOpt2 or "Above"
                                dist = _G.DistOpt2 or 5
                            elseif ActiveMonsterType == 3 then
                                dir = _G.DirOpt3 or "Above"
                                dist = _G.DistOpt3 or 5
                            end
                            local offset
                            if dir == "Above" then
                                offset = CFrame.new(0, dist, 0)
                            elseif dir == "Below" then
                                offset = CFrame.new(0, -dist, 0)
                            elseif dir == "Front" then
                                offset = CFrame.new(0, 0, -dist)
                            else
                                offset = CFrame.new(0, 0, dist)
                            end
                            myRoot.CFrame = rootPart.CFrame * offset
                        end
                    end
                end
            end)
            task.wait(0.08)
        else
            ActiveMonsterTarget = nil
            ActiveMonsterType = nil
            task.wait(0.5)
        end
    end
end)

-- ==========================================
-- LOOPS: AUTO CHEST TELEPORTER
-- ==========================================
task.spawn(function()
    while true do
        if _G.AutoChestEnabled then
            pcall(function()
                local char = LocalPlayer.Character
                local myRoot = char and char:FindFirstChild("HumanoidRootPart")
                if myRoot then
                    local activeChests = getActiveChests()
                    
                    if #activeChests == 0 then
                        chestWaitingForRespawn = true
                        task.wait(1)
                        return
                    end
                    
                    if chestWaitingForRespawn then
                        chestWaitingForRespawn = false
                        chestIndex = 1
                    end
                    
                    local currentTime = tick()
                    
                    if currentTime - lastChestTpTime >= chestTpDelay then
                        if chestIndex <= #activeChests then
                            local chest = activeChests[chestIndex]
                            
                            if chest then
                                myRoot.CFrame = chest.CFrame
                                chestIndex = chestIndex + 1
                                lastChestTpTime = currentTime
                            else
                                chestIndex = chestIndex + 1
                            end
                        else
                            chestIndex = 1
                            chestWaitingForRespawn = true
                        end
                    end
                end
            end)
            task.wait(0.05)
        else
            chestIndex = 1
            chestWaitingForRespawn = false
            task.wait(0.5)
        end
    end
end)
