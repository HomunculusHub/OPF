local function simulateKeyPress(keyCode)
    VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
    task.wait(0.02)
    VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
end

local function CheckValidTarget(obj)
    if obj and obj.Parent and obj:IsDescendantOf(workspace) then
        local h = obj:FindFirstChildOfClass("Humanoid")
        if h and h.Health > 0 then return true end
    end
    return false
end

local function FindTargetFromWorkspace(keyword)
    for _, v in pairs(workspace:GetChildren()) do
        if v:IsA("Model") and string.find(v.Name, keyword) then
            local h = v:FindFirstChildOfClass("Humanoid")
            if h and h.Health > 0 then return v end
        end
    end
    for _, folder in pairs(workspace:GetChildren()) do
        if folder:IsA("Folder") or folder:IsA("Model") then
            for _, v in pairs(folder:GetChildren()) do
                if v:IsA("Model") and string.find(v.Name, keyword) then
                    local h = v:FindFirstChildOfClass("Humanoid")
                    if h and h.Health > 0 then return v end
                end
            end
        end
    end
    return nil
end

local function ClickSpawnButton()
    local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
    if not playerGui then return end
    for _, gui in pairs(playerGui:GetDescendants()) do
        if gui:IsA("TextButton") or gui:IsA("ImageButton") then
            local nl = string.lower(gui.Name)
            local tl = gui:IsA("TextButton") and string.lower(gui.Text) or ""
            if (string.find(nl,"spawn") or string.find(tl,"spawn") or
                string.find(nl,"respawn") or string.find(tl,"respawn") or
                string.find(nl,"play") or string.find(tl,"play") or
                string.find(nl,"start") or string.find(tl,"start") or
                string.find(nl,"retry") or string.find(tl,"retry")) and
                gui.Visible and gui.AbsoluteSize.X > 0 then
                if firesignal then
                    firesignal(gui.MouseButton1Click)
                    firesignal(gui.Activated)
                else
                    gui:Activate()
                end
            end
        end
    end
end

local function getActiveChests()
    local active = {}
    if not chestsFolder then return active end
    for _, chest in ipairs(chestsFolder:GetChildren()) do
        if chest:IsA("Model") or chest:IsA("BasePart") then
            table.insert(active, chest)
        end
    end
    return active
end

